# =============================================================================
# tesla-skill configuration
# Copy to .env and fill in. Never commit .env (it's in .gitignore).
# =============================================================================

# ---- Mode ----
# true:  All tools return mock data. Useful for development before Tesla is set up.
# false: Real Fleet API + signed control commands.
USE_MOCK=true

# ---- Tesla Developer credentials (from developer.tesla.com or developer.tesla.cn) ----
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=

# Must match exactly what you registered in the developer portal.
# For local-only setup, use http://localhost:8765/callback (Tesla allows this).
TESLA_REDIRECT_URI=https://your.domain.com/oauth/callback

# ---- Tesla API region ----
# China-region vehicles (built/sold in China):
TESLA_FLEET_API_BASE=https://fleet-api.prd.cn.vn.cloud.tesla.cn
TESLA_AUTH_BASE=https://auth.tesla.cn
#
# North America / Europe / rest of world:
# TESLA_FLEET_API_BASE=https://fleet-api.prd.na.vn.cloud.tesla.com
# TESLA_AUTH_BASE=https://auth.tesla.com
#
# (EU vehicles use fleet-api.prd.eu.vn.cloud.tesla.com)

# ---- Token-at-rest encryption ----
# Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ---- Data directory ----
# Where tokens.db, tesla_keys/, bin/ are stored. Defaults to ~/.tesla-skill/
# TESLA_SKILL_DATA_DIR=~/.tesla-skill

# ---- Virtual Key signing (for control commands; can leave blank until Phase 9) ----
# Path to your Virtual Key private PEM (generated by scripts/generate_virtual_key.py)
TESLA_PRIVATE_KEY_PATH=~/.tesla-skill/tesla_keys/private.pem
# Path to the tesla-control Go binary (built from github.com/teslamotors/vehicle-command)
TESLA_CONTROL_BINARY=~/.tesla-skill/bin/tesla-control
